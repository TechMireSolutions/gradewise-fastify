{
  "name": "grade-wise-ai-backend-fastify",
  "version": "1.0.0",
  "description": "GradeWise AI Backend — Fastify + TypeScript + Drizzle ORM",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "fastify-type-provider-zod": "^6.1.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5",
    "zod": "^4.4.3",
    "ai": "^6.0.206",
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/groq": "^3.0.41",
    "@ai-sdk/mistral": "^3.0.39",
    "bcrypt": "^5.1.1",
    "nodemailer": "^6.10.1",
    "dotenv": "^16.6.1",
    "uuid": "^11.1.0",
    "axios": "^1.9.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.17.2",
    "sharp": "^0.34.2",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsx": "^4.19.3",
    "drizzle-kit": "^0.31.10",
    "@types/node": "^22.15.29",
    "@types/bcrypt": "^5.0.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.17.6",
    "@types/pdf-parse": "^1.1.5"
  }
}
