# ── Server ──────────────────────────────────────────────────────────────
PORT=5005
NODE_ENV=development
HOST=0.0.0.0

# ── Database (PostgreSQL) ────────────────────────────────────────────────
# External aaPanel-managed Postgres
# Note: '@' in password must be URL-encoded as '%40'
DATABASE_URL=postgresql://gradewiseai:Gradewise%40ai2026@localhost:5432/gradewiseai

# ── CORS / Frontend ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000,http://localhost:5173

# ── Auth / Security ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_64_char_random_string_in_production
JWT_EXPIRES_IN=24h

# ── reCAPTCHA ───────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_here
SKIP_CAPTCHA=false

# ── AI Providers — comma-separated keys for round-robin ─────────────────
# TEXT purpose (question generation, evaluation, feedback)
TEXT_GEMINI_KEYS=
TEXT_GEMINI_MODEL=gemini-2.5-flash

TEXT_GROQ_KEYS=
TEXT_GROQ_MODEL=llama-3.3-70b-versatile

TEXT_OPENAI_KEYS=
TEXT_OPENAI_MODEL=gpt-4o-mini

TEXT_CLAUDE_KEYS=
TEXT_CLAUDE_MODEL=claude-sonnet-4-6

TEXT_MISTRAL_KEYS=
TEXT_MISTRAL_MODEL=mistral-small-latest

TEXT_DEEPSEEK_KEYS=
TEXT_DEEPSEEK_MODEL=deepseek-chat

# PDF purpose (document text extraction)
PDF_GEMINI_KEYS=
PDF_GEMINI_MODEL=gemini-2.5-flash

# ── Email (nodemailer) ──────────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@gradewise.ai

# ── Redis / Upstash (optional — rate limiting, caching) ─────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── File uploads ────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
