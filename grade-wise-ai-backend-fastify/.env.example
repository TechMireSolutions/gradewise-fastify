# Server
NODE_ENV=development
PORT=5005
HOST=0.0.0.0

# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gradewise

# Auth (required)
JWT_SECRET=change_me_to_a_64_char_random_string_in_production
JWT_EXPIRES_IN=24h
COOKIE_SECRET=
ENCRYPTION_KEY=change_me_to_a_32_char_secret_for_ai_keys

# Google / Firebase token verification
FIREBASE_PROJECT_ID=
GOOGLE_CLIENT_ID=

# CORS
FRONTEND_URL=http://localhost:3000

# Redis (optional — enables async jobs + distributed rate limiting)
REDIS_URL=redis://localhost:6379
USE_ASYNC_JOBS=false

# Object storage (optional — MinIO in docker-compose)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=gradewise
S3_REGION=us-east-1

# Email (optional — needed for verification/reset emails)
EMAIL_USER=
EMAIL_PASS=

# reCAPTCHA (optional in development — SKIP_CAPTCHA defaults via NODE_ENV=development)
RECAPTCHA_SECRET_KEY=
SKIP_CAPTCHA=true

# Uploads
MAX_FILE_SIZE_MB=20

# AI providers (optional — can also be configured via Super Admin UI after seed)
TEXT_GEMINI_KEYS=
TEXT_GEMINI_MODEL=gemini-2.5-flash
PDF_GEMINI_KEYS=
PDF_GEMINI_MODEL=gemini-2.5-flash
TEXT_GROQ_KEYS=
TEXT_GROQ_MODEL=llama-3.3-70b-versatile
TEXT_OPENAI_KEYS=
TEXT_OPENAI_MODEL=gpt-4o-mini
TEXT_CLAUDE_KEYS=
TEXT_CLAUDE_MODEL=claude-sonnet-4-6
TEXT_MISTRAL_KEYS=
TEXT_MISTRAL_MODEL=mistral-small-latest
TEXT_DEEPSEEK_KEYS=
TEXT_DEEPSEEK_MODEL=deepseek-chat
